# Site identity surfaced in /healthz and the audit log.
COORDINATOR_SITE_ID=local

# Local Bacalhau REST endpoint. The coordinator only reads from this.
COORDINATOR_BACALHAU_API_URL=http://localhost:1234

# Path or name of the Nextflow binary.
COORDINATOR_NEXTFLOW_BINARY=nextflow

# Directory containing the federated-AF main.nf.
COORDINATOR_PIPELINE_ROOT=/absolute/path/to/examples/federated-af

# Per-run workdirs + state snapshot + audit log live here.
COORDINATOR_WORKDIR_ROOT=/tmp/site-coordinator-runs

# Bearer token required for POST /v1/runs and cancel. Leave unset to
# disable all writes (fail-closed).
COORDINATOR_OPERATOR_TOKEN=change-me-to-a-long-random-value
