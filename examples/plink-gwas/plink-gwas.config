/*
 * Configuration for PLINK GWAS Meta-Analysis on Bacalhau
 */

// ==============================================================================
// COHORT CONFIGURATION - Define your institutions here
// ==============================================================================

params {
    // Output directory
    outdir = 'results'

    // Meta-analysis node (optional) - specify which node runs the meta-analysis
    // If not specified, runs on any available Bacalhau node
    metaAnalysisNode = null  // e.g., 'node-coordinator' or 'node-institute-a'

    // Cohort definitions - customize for your study
    // Each cohort specifies:
    //   - name: cohort identifier
    //   - node: which Bacalhau node to run on
    //   - storage_type: 'local' or 's3'
    //   - data_path: local path (for host://) or S3 URL
    //   - s3_credentials: (optional) env vars for S3 access

    cohorts = [
        // Institute A: Data on local HPC storage
        [
            name: 'institute_a',
            node: 'node-institute-a',
            storage_type: 'local',
            data_path: '/data/genomics/cohort_a/institute_a'
        ],

        // Institute B: Data in their private S3 bucket
        [
            name: 'institute_b',
            node: 'node-institute-b',
            storage_type: 's3',
            data_path: 's3://institute-b-genomics/cohort_b/institute_b',
            s3_credentials: ['INSTITUTE_B_AWS_KEY', 'INSTITUTE_B_AWS_SECRET']
        ],

        // Institute C: Data on local NFS storage
        [
            name: 'institute_c',
            node: 'node-institute-c',
            storage_type: 'local',
            data_path: '/mnt/nfs/genomics/institute_c'
        ],

        // Institute D: Data in their private S3 bucket (different from B)
        [
            name: 'institute_d',
            node: 'node-institute-d',
            storage_type: 's3',
            data_path: 's3://institute-d-private-data/gwas/institute_d',
            s3_credentials: ['INSTITUTE_D_AWS_KEY', 'INSTITUTE_D_AWS_SECRET']
        ]
    ]
}

// ==============================================================================
// BACALHAU EXECUTOR CONFIGURATION
// ==============================================================================

// Bacalhau executor configuration
process {
    executor = 'bacalhau'

    // Default resources
    cpus = 2
    memory = '4.GB'
    time = '30m'

    // Bacalhau-specific settings
    ext {
        bacalhauNode = 'https://api.bacalhau.org'
        waitForCompletion = true
        maxRetries = 2
        storageEngine = 'ipfs'

        // S3 credentials - multiple approaches supported:

        // Option 1: Single shared S3 credentials (simple)
        // bacalhauSecrets = ['AWS_ACCESS_KEY_ID', 'AWS_SECRET_ACCESS_KEY']

        // Option 2: Per-institution S3 credentials (recommended for multi-institution)
        // Each institution provides their own S3 credentials as env vars
        // Example:
        //   export INSTITUTE_A_AWS_KEY="..."
        //   export INSTITUTE_A_AWS_SECRET="..."
        //   export INSTITUTE_B_AWS_KEY="..."
        //   export INSTITUTE_B_AWS_SECRET="..."
        //
        // Then specify in workflow's cohort config:
        //   s3_credentials: ['INSTITUTE_A_AWS_KEY', 'INSTITUTE_A_AWS_SECRET']
        //
        // This allows each institution to:
        //   - Use their own S3 bucket
        //   - Maintain their own credentials
        //   - No credential sharing between institutions
    }

    // Process-specific overrides
    withName: 'runGWAS' {
        cpus = 2
        memory = '4.GB'
        time = '30m'
    }

    withName: 'metaAnalysis' {
        cpus = 4
        memory = '8.GB'
        time = '1h'
    }
}

// Docker configuration
docker {
    enabled = true
    runOptions = '--rm'
}

// Execution reports
trace {
    enabled = true
    file = 'plink-gwas-trace.txt'
    fields = 'task_id,hash,native_id,process,tag,status,exit,duration,realtime,cpus,memory,%cpu,%mem,rss'
}

timeline {
    enabled = true
    file = 'plink-gwas-timeline.html'
}

report {
    enabled = true
    file = 'plink-gwas-report.html'
}
