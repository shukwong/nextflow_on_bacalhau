/*
 * Federated PLINK GWAS meta-analysis demo — Bacalhau executor config.
 *
 * Mirrors examples/federated-af/nextflow.config. The load-bearing settings:
 *   - plugins { id 'nf-bacalhau@0.1.0' }  : activates the executor (required).
 *   - process.stageInMode = 'copy'        : the Bacalhau container mounts only
 *     the task workDir, so Nextflow's default symlinked inputs would dangle
 *     inside the container. 'copy' materialises real files.
 *   - bacalhau { } scope                  : the dedicated, supported place for
 *     executor settings (bacalhauNode / bacalhauCliPath).
 *
 * NOTE ON LIMITATIONS (read examples/plink-gwas/README.md):
 *   - The executor has NO node-targeting. Each cohort job is scheduled on
 *     whatever node Bacalhau picks; you cannot pin a cohort to an institution's
 *     node from the plugin. For a real federation, data locality is a
 *     deployment concern (run a node per site, restrict it to that site's data).
 *   - S3 inputs use a single, run-wide credential set via
 *     `process.ext.bacalhauSecrets`. There is no per-cohort credential support.
 */

params {
    // Directory holding the per-cohort PLINK text filesets (<cohort>.ped/.map/.cov).
    // The run.sh harness generates these under a temp dir; override as needed.
    data_dir = "${projectDir}/data"
    outdir   = 'results'
}

bacalhau {
    bacalhauCliPath = 'bacalhau'
    bacalhauNode    = 'http://localhost:1234'
}

process {
    executor    = 'bacalhau'
    stageInMode = 'copy'

    cpus   = 1
    memory = '2.GB'
    time   = '30m'

    withName: 'runGWAS' {
        cpus   = 2
        memory = '4.GB'
        time   = '30m'
    }

    withName: 'metaAnalysis' {
        cpus   = 2
        memory = '4.GB'
        time   = '30m'
    }

    // S3 inputs (optional): forward a single, run-wide credential set to every
    // job. These are env-var NAMES resolved from the Nextflow launch shell.
    // ext.bacalhauSecrets = ['AWS_ACCESS_KEY_ID', 'AWS_SECRET_ACCESS_KEY']
}

docker {
    enabled    = true
    runOptions = '--rm'
}

plugins { id 'nf-bacalhau@0.1.0' }
