/*
 * Example configuration for the Bacalhau executor.
 *
 * Config key priority (highest to lowest):
 *   1. bacalhau { }          — executor-level globals (preferred)
 *   2. process { ext { } }   — legacy fallback (still supported)
 */

// ---------------------------------------------------------------------------
// Executor-level Bacalhau settings (FIX #12: use this block, not process.ext)
// ---------------------------------------------------------------------------
bacalhau {
    // Bacalhau API endpoint (default: public API)
    bacalhauNode = 'https://api.bacalhau.org'

    // Path to the bacalhau binary (default: resolved from PATH)
    // bacalhauCliPath = '/usr/local/bin/bacalhau'

    // Storage engine used for job inputs (ipfs | s3 | local)
    storageEngine = 'ipfs'

    // Number of times to retry a failed job submission
    maxRetries = 3
}

// ---------------------------------------------------------------------------
// Process defaults
// ---------------------------------------------------------------------------
process {
    executor  = 'bacalhau'
    container = 'ubuntu:latest'

    cpus   = 1
    memory = '1 GB'
    time   = '10 min'
}

// ---------------------------------------------------------------------------
// Polling monitor tuning (FIX #10/#11 — replaces 5s HPC default with 30s)
//
// Bacalhau jobs run for minutes to hours; polling every 5s is wasteful.
// These values are resolved by BacalhauTaskMonitor.create().
// ---------------------------------------------------------------------------
executor {
    $bacalhau {
        pollInterval = '30 sec'   // how often to check job status
        queueSize    = 100        // max concurrent Bacalhau jobs tracked
        dumpInterval = '5 min'    // how often to log queue diagnostics
    }
}

// ---------------------------------------------------------------------------
// Observability
// ---------------------------------------------------------------------------
trace {
    enabled = true
    file    = 'bacalhau-trace.txt'
}

timeline {
    enabled = true
    file    = 'bacalhau-timeline.html'
}

report {
    enabled = true
    file    = 'bacalhau-report.html'
}
