/*
 * Example configuration for Bacalhau executor
 */

// Bacalhau executor-level settings (preferred over process.ext)
bacalhau {
    bacalhauNode = 'https://api.bacalhau.org'
    waitForCompletion = true
    maxRetries = 3
    storageEngine = 'ipfs'
    s3Region = 'us-east-1'
}

// Configure the Bacalhau executor
process {
    executor = 'bacalhau'

    // Default container for all processes
    container = 'ubuntu:latest'

    // Default resource limits
    cpus = 1
    memory = '1.GB'
    time = '10m'
}

// Docker configuration
docker {
    enabled = true
    runOptions = '--rm'
}

// Enable detailed logging
trace {
    enabled = true
    file = 'bacalhau-trace.txt'
}

// Timeline and execution reports
timeline {
    enabled = true
    file = 'bacalhau-timeline.html'
}

report {
    enabled = true
    file = 'bacalhau-report.html'
}