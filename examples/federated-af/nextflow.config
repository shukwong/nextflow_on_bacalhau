/*
 * Federated allele-frequency demo — Bacalhau executor config.
 *
 * stageInMode = 'copy' is required so input VCFs are copied into the task
 * workDir. The Bacalhau container mounts only the workDir, so symlinked
 * inputs (Nextflow's default) would dangle inside the container.
 */

bacalhau {
    bacalhauCliPath   = 'bacalhau'
    bacalhauNode      = 'http://localhost:1234'
    waitForCompletion = true
    maxRetries        = 1
    storageEngine     = 'local'
}

process {
    executor    = 'bacalhau'
    cpus        = 1
    memory      = '512.MB'
    time        = '10m'
    stageInMode = 'copy'
}

docker {
    enabled    = true
    runOptions = '--rm'
}

plugins { id 'nf-bacalhau@0.1.0' }
